{
  "examples": [
    {
      "title": "Aspirin dose disagreement across 3 sources",
      "endpoint": "POST /api/reconcile",
      "payload": {
        "patient_id": "PT-1001",
        "sources": [
          {
            "source_name": "Hospital EHR",
            "drug_name": "Aspirin",
            "dose": "81mg",
            "frequency": "once daily",
            "last_updated": "2025-12-01",
            "reliability": "high"
          },
          {
            "source_name": "Pharmacy System",
            "drug_name": "Aspirin",
            "dose": "325mg",
            "frequency": "once daily",
            "last_updated": "2025-11-20",
            "reliability": "high"
          },
          {
            "source_name": "Patient Self-Report",
            "drug_name": "Aspirin",
            "dose": "81mg",
            "frequency": "every other day",
            "last_updated": "2025-10-15",
            "reliability": "low"
          }
        ],
        "patient_context": {
          "age": 68,
          "conditions": ["Coronary Artery Disease", "Hypertension"],
          "allergies": [],
          "lab_values": {}
        }
      }
    },
    {
      "title": "Metformin with low eGFR (drug-disease contraindication)",
