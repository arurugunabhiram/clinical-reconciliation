          },
          {
            "source_name": "Endocrinology Clinic",
            "drug_name": "Metformin",
            "dose": "1000mg",
            "frequency": "twice daily",
            "last_updated": "2025-12-08",
            "reliability": "high"
          }
        ],
        "patient_context": {
          "age": 72,
