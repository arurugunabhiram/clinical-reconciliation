ANTHROPIC_API_KEY=your-anthropic-api-key-here
API_KEY=your-api-secret-key-here
PORT=8080

# Comma-separated list of allowed frontend origins for backend CORS.
CORS_ORIGINS=http://localhost:5173
# Base URL used by the frontend to call the backend API.
VITE_API_BASE_URL=http://localhost:8000
# API key entered by users in the frontend.
VITE_API_KEY=your_api_key_here
# Supabase project URL for client-side decision logging.
VITE_SUPABASE_URL=your_supabase_project_url
# Supabase anonymous key for client-side decision logging.
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
